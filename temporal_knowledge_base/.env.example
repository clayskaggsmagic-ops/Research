# === CHRONOS Environment Variables ===

# Google AI (for research LLM + embeddings)
GOOGLE_API_KEY=your-google-api-key

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chronos

# Web search (pick one)
SERPER_API_KEY=your-serper-key
# OR use Google Search via Gemini grounding (no extra key needed)

# GDELT (free, no key needed)
# ACLED (optional)
ACLED_API_KEY=your-acled-key

# Optional: Anthropic for cross-model validation
ANTHROPIC_API_KEY=your-anthropic-key
